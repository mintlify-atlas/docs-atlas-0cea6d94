{
  "projectType": "framework",
  "projectName": "Gova",
  "projectDescription": "A declarative GUI framework for Go that lets developers build native desktop apps for macOS, Windows, and Linux using typed struct components, reactive state, and a single static binary.",
  "theme": "palm",
  "primaryColor": "#84847c",
  "lightColor": "#161616",
